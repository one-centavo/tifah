# --- EXAMPLE CONFIGURATION FOR MSMTP ---

defaults
auth           off
tls            off
logfile        /var/www/html/storage/logs/msmtp.log

# OPTION 1: Development Environment (Mailpit)
account        default
host           mailpit
port           1025
from           admin@gymadm.local

# OPTION 2: Production Enviroment
# To use this, change 'http' to 'un', 'tls' to 'on' and uncomment the lines below.
# account        production
# host           smtp.gmail.com
# port           587
# auth           on
# user           your_user@gmail.com
# password       your_password_or_token_here
# from           your_email@gmail.com
# tls            on
# tls_starttls   on